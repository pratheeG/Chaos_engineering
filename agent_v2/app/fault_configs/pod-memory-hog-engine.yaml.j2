# Jinja2 template: pod-memory-hog ChaosEngine step
# Rendered once per target deployment by generate_chaos_engines().
#
# Required variables:
#   engine_id              - short unique suffix, e.g. "r01", "r02"
#   target_namespace       - Kubernetes namespace of the target app
#   app_label              - Kubernetes label selector, e.g. "app=chaos-backend"
#   target_container       - Name of the container to target
#   chaos_duration         - Duration in seconds as a string, e.g. "60"
#   memory_consumption_mib - Memory to consume in MiB, e.g. "500"
#   probe_ref              - JSON probe annotation, e.g. '[{"name":"my-probe","mode":"Continuous"}]'
#                            Pass '[]' for no probes.

- name: pod-memory-hog-{{ engine_id }}
  inputs:
    artifacts:
      - name: pod-memory-hog-{{ engine_id }}
        path: /tmp/chaosengine-pod-memory-hog-{{ engine_id }}.yaml
        raw:
          data: |
            apiVersion: litmuschaos.io/v1alpha1
            kind: ChaosEngine
            metadata:
              namespace: "{{"{{"}}workflow.parameters.adminModeNamespace{{"}}"}}"
              labels:
                workflow_run_id: "{{"{{"}} workflow.uid {{"}}"}}"
              annotations:
                probeRef: '{{ probe_ref }}'
              generateName: pod-memory-hog-{{ engine_id }}-
            spec:
              appinfo:
                appns: {{ target_namespace }}
                applabel: {{ app_label }}
                appkind: deployment
              engineState: active
              chaosServiceAccount: litmus-admin
              experiments:
                - name: pod-memory-hog
                  spec:
                    components:
                      env:
                        - name: TOTAL_CHAOS_DURATION
                          value: "{{ chaos_duration }}"
                        - name: RAMP_TIME
                          value: ""
                        - name: MEMORY_CONSUMPTION
                          value: "{{ memory_consumption_mib }}"
                        - name: NUMBER_OF_WORKERS
                          value: "1"
                        - name: PODS_AFFECTED_PERC
                          value: ""
                        - name: TARGET_CONTAINER
                          value: "{{ target_container }}"
                        - name: TARGET_PODS
                          value: ""
                        - name: DEFAULT_HEALTH_CHECK
                          value: "false"
                        - name: NODE_LABEL
                          value: ""
                        - name: SEQUENCE
                          value: parallel
  metadata:
    labels:
      weight: "10"
  container:
    name: ""
    image: docker.io/litmuschaos/litmus-checker:2.11.0
    args:
      - -file=/tmp/chaosengine-pod-memory-hog-{{ engine_id }}.yaml
      - -saveName=/tmp/engine-name
