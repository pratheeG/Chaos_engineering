# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose "openai" or "groq"
LLM_PROVIDER=groq

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── LitmusChaos ──────────────────────────────────────────────────────────────
LITMUS_API_URL=http://localhost:9002/api/query
LITMUS_PROJECT_ID=
LITMUS_ACCESS_TOKEN=

# Obtain the token by logging in:
#   curl -s -X POST http://localhost:9002/auth/login \
#     -H 'Content-Type: application/json' \
#     -d '{"username":"admin","password":"litmus"}' | jq -r '.access_token'
