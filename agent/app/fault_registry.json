{
  "pod-delete": {
    "description": "Deletes pods to test resilience and restart recovery.",
    "template": "pod-delete-engine.yaml.j2",
    "install_yaml": "pod-delete-install.yaml",
    "k8s_signals": ["Killing", "Started", "Pulled", "BackOff"],
    "parameters": {
      "chaos_duration": {"type": "str", "required": true, "description": "Fault duration in seconds"},
      "target_namespace": {"type": "str", "required": true, "description": "Kubernetes namespace"},
      "app_label":        {"type": "str", "required": true, "description": "Label selector e.g. app=foo"},
      "target_container": {"type": "str", "required": true, "description": "Container name to target"},
      "probe_name":       {"type": "str", "required": false, "default": "", "description": "Probe name or empty"}
    }
  },
  "pod-cpu-hog": {
    "description": "Stresses CPU on a pod to test throttling and performance degradation.",
    "template": "pod-cpu-hog-engine.yaml.j2",
    "install_yaml": "pod-cpu-hog-install.yaml",
    "k8s_signals": ["OOMKilling", "SystemOOM", "Evicted", "Preempted"],
    "parameters": {
      "chaos_duration": {"type": "str", "required": true,  "description": "Fault duration in seconds"},
      "target_namespace":{"type": "str", "required": true,  "description": "Kubernetes namespace"},
      "app_label":       {"type": "str", "required": true,  "description": "Label selector e.g. app=foo"},
      "target_container":{"type": "str", "required": true,  "description": "Container name to target"},
      "cpu_cores":       {"type": "str", "required": false, "default": "1",   "description": "Number of CPU cores to stress"},
      "cpu_load":        {"type": "str", "required": false, "default": "100", "description": "CPU load % per core"},
      "probe_name":      {"type": "str", "required": false, "default": "",    "description": "Probe name or empty"}
    }
  },
  "pod-memory-hog": {
    "description": "Stresses memory on a pod to test OOM handling and eviction.",
    "template": "pod-memory-hog-engine.yaml.j2",
    "install_yaml": "pod-memory-hog-install.yaml",
    "k8s_signals": ["OOMKilling", "SystemOOM", "Evicted"],
    "parameters": {
      "chaos_duration": {"type": "str", "required": true,  "description": "Fault duration in seconds"},
      "target_namespace":{"type": "str", "required": true,  "description": "Kubernetes namespace"},
      "app_label":       {"type": "str", "required": true,  "description": "Label selector e.g. app=foo"},
      "target_container":{"type": "str", "required": true,  "description": "Container name to target"},
      "memory_consumption_mib": {"type": "str", "required": false, "default": "500", "description": "Memory to consume in MiB"},
      "probe_name":      {"type": "str", "required": false, "default": "",    "description": "Probe name or empty"}
    }
  }
}
